{
  "name": "my-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:api": "node scripts/generate-docs.mjs",
    "sync:api:report": "node scripts/sync/index.mjs --mode=report",
    "sync:api:update": "node scripts/sync/index.mjs --mode=update",
    "prebuild": "pnpm generate:api",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@radix-ui/react-presence": "^1.1.5",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "^10.3.14",
    "fumadocs-ui": "16.6.8",
    "hast": "^1.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "patchedDependencies": {
      "fumadocs-openapi": "patches/fumadocs-openapi.patch"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}